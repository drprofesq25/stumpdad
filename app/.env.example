# StumpDad backend configuration
# Copy this file to ".env" and fill in ONE provider's key. NEVER commit .env.
#
# The server auto-selects the provider: if ANTHROPIC_API_KEY is set it uses
# Claude; otherwise it uses GEMINI_API_KEY. Force one with PROVIDER=anthropic|gemini.

# --- Option A (recommended): Anthropic Claude ---
# Fast, cheap, great at strict JSON + kid-safe rules. Get a key:
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Option B: Google Gemini ---
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Force a provider (optional): anthropic | gemini
# PROVIDER=anthropic

# --- Premium host voice (OpenAI TTS) — OPTIONAL ---
# If set, questions are read by a charismatic game-show voice. If blank, the app
# falls back to the device's built-in voice automatically. Key:
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash
# Optional: override the host's delivery style.
# OPENAI_TTS_INSTRUCTIONS=You are an energetic, charismatic game-show host...

# Port the Express server listens on (nginx proxies to this).
PORT=8088
